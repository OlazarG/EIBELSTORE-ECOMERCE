# ###########################################################
# .dockerignore para EIBELSTORE
# ###########################################################

# Ignora las carpetas de librerías locales (se instalan dentro del contenedor)
node_modules/
backend/node_modules/

# Ignora archivos de configuración local y secretos
.env
backend/.env
backend/error_debug.log

# Ignora datos locales del sistema operativo
.git
.gitignore
.dockerignore
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignora archivos temporales de editores
.vscode/
.idea/
*.swp
*.swo

# Ignora carpetas de subida de archivos (si se manejan fuera del contenedor o en volúmenes)
backend/uploads/
